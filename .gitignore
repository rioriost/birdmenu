# Ignore everything by default, then allow only files intended for the public
# repository.
*

!/.gitignore
!/LICENSE
!/Makefile
!/Package.swift
!/project.yml
!/README.md
!/BirdMenu.entitlements
!/ExportOptions.appstore.plist

!/BirdMenu.xcodeproj/
!/BirdMenu.xcodeproj/project.pbxproj
!/BirdMenu.xcodeproj/project.xcworkspace/
!/BirdMenu.xcodeproj/project.xcworkspace/contents.xcworkspacedata
!/BirdMenu.xcodeproj/xcshareddata/
!/BirdMenu.xcodeproj/xcshareddata/xcschemes/
!/BirdMenu.xcodeproj/xcshareddata/xcschemes/*.xcscheme

!/Assets/
!/Assets/AppIcon.iconset/
!/Assets/AppIcon.iconset/*.png
!/Assets/IconConcepts/
!/Assets/IconConcepts/*.png

!/Resources/
!/Resources/BirdMenu.icns
!/Resources/Info.plist

!/Sources/
!/Sources/BirdMenu/
!/Sources/BirdMenu/*.swift

!/Tests/
!/Tests/BirdMenuTests/
!/Tests/BirdMenuTests/*.swift

!/Tools/
!/Tools/*.js

!/docs/
!/docs/*.md

!/images/
!/images/*.png

# Local build products and generated runtime data.
.build/
build/
logs/
*.btsnoop
*.pklg
*.xcarchive
*.dSYM/

# User and system metadata.
.DS_Store
*.swp
*.tmp
